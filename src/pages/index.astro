---
// Root page: immediately redirect based on browser language.
// Falls back to en/ for any non-Polish language.
// No cookies used — navigator.language is read fresh every visit.
// Uses a relative redirect so it works under any base path.
---

<!doctype html>
<html>
  <head>
    <meta charset="UTF-8" />
    <meta name="robots" content="noindex" />
    <!-- Fallback for no-JS: relative redirect to English -->
    <meta http-equiv="refresh" content="0; url=en/" />
    <script is:inline>
      (function () {
        var lang = navigator.language || navigator.userLanguage || '';
        // Ensure current path ends with a slash before appending the locale
        var base = window.location.pathname.replace(/\/?$/, '/');
        if (lang.toLowerCase().startsWith('pl')) {
          window.location.replace(base + 'pl/');
        } else {
          window.location.replace(base + 'en/');
        }
      })();
    </script>
  </head>
  <body></body>
</html>
