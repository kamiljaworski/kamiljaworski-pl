---
import type { Translations } from '../i18n/translations';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section id="about" aria-label={t.about.heading} class="mb-16 scroll-mt-16 lg:mb-24 lg:scroll-mt-24">
  <div class="sticky top-0 z-20 -mx-6 mb-4 w-screen px-6 py-5 backdrop-blur md:-mx-12 md:px-12 lg:relative lg:top-auto lg:mx-auto lg:w-full lg:bg-transparent lg:px-0 lg:py-0 lg:backdrop-blur-none" style="background-color: rgba(13,17,23,0.85);">
    <h2 class="text-sm font-bold uppercase tracking-widest lg:hidden" style="color: var(--color-heading)">
      {t.about.heading}
    </h2>
  </div>

  <div class="flex flex-col gap-4">
    {t.about.body.map((paragraph) => (
      <p class="leading-relaxed" style="color: var(--color-text-muted)">{paragraph}</p>
    ))}
  </div>
</section>
