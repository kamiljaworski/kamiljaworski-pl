---
import type { Translations, Lang } from '../i18n/translations';

interface Props {
  t: Translations;
  lang: Lang;
}

const { t, lang } = Astro.props;

const navItems = [
  { href: '#about',        label: t.nav.about        },
  { href: '#experience',   label: t.nav.experience   },
  { href: '#certificates', label: t.nav.certificates },
  ...(lang === 'pl' ? [{ href: '#projects', label: t.nav.projects }] : []),
  { href: '#skills',       label: t.nav.skills       },
  { href: '#contact',      label: t.nav.contact      },
];

const langToggle = lang === 'pl'
  ? { label: 'EN', href: '/en/', title: 'Switch to English' }
  : { label: 'PL', href: '/', title: 'Przełącz na polski' };
---

<header class="flex flex-col gap-4 lg:sticky lg:top-0 lg:max-h-screen lg:justify-between lg:py-24">
  <div>
    <h1 class="text-4xl font-bold tracking-tight sm:text-5xl" style="color: var(--color-heading)">
      {t.hero.name}
    </h1>
    <h2 class="mt-3 text-base font-medium tracking-wide" style="color: var(--color-accent-light)">
      {t.hero.title}
    </h2>
    <p class="mt-4 max-w-xs leading-relaxed text-sm" style="color: var(--color-text-muted)">
      {t.hero.tagline}
    </p>

    <!-- Numbered nav — desktop only -->
    <nav class="mt-12 hidden lg:block" aria-label="On-page sections">
      <ul class="flex flex-col gap-3">
        {navItems.map(({ href, label }, i) => (
          <li>
            <a href={href} class="nav-link">
              <span class="nav-num">{String(i + 1).padStart(2, '0')}</span>
              {label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>

  <!-- Socials -->
  <div class="flex items-center gap-5 mt-8">
    <!-- GitHub -->
    <a
      href="https://github.com/kamiljaworski"
      target="_blank"
      rel="noopener noreferrer"
      class="social-link"
      aria-label="GitHub"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="22" height="22">
        <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
      </svg>
    </a>

    <!-- LinkedIn -->
    <a
      href="https://www.linkedin.com/in/jaworskikamil/"
      target="_blank"
      rel="noopener noreferrer"
      class="social-link"
      aria-label="LinkedIn"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="22" height="22">
        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
      </svg>
    </a>

    <!-- Email -->
    <a
      href="mailto:kontakt@kamiljaworski.pl"
      class="social-link"
      aria-label="Email"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="22" height="22">
        <rect width="20" height="16" x="2" y="4" rx="2"/>
        <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
      </svg>
    </a>
    <!-- Language toggle -->
    <a
      href={langToggle.href}
      class="social-link text-xs font-bold tracking-widest uppercase"
      aria-label={langToggle.title}
      title={langToggle.title}
      data-lang={langToggle.label.toLowerCase()}
      id="lang-toggle"
    >
      {langToggle.label}
    </a>
  </div>
</header>

<script>
  const toggle = document.getElementById('lang-toggle');
  if (toggle) {
    toggle.addEventListener('click', () => {
      const targetLang = toggle.getAttribute('data-lang');
      localStorage.setItem('preferred-lang', targetLang);
    });
  }
</script>
