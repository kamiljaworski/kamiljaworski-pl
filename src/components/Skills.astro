---
import type { Translations } from '../i18n/translations';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<section id="skills" aria-label={t.skills.heading} class="mb-16 scroll-mt-16 lg:mb-24 lg:scroll-mt-24">
  <div class="sticky top-0 z-20 -mx-6 mb-4 w-screen bg-slate-900/75 px-6 py-5 backdrop-blur md:-mx-12 md:px-12 lg:relative lg:top-auto lg:mx-auto lg:w-full lg:bg-transparent lg:px-0 lg:py-0 lg:backdrop-blur-none">
    <h2 class="text-sm font-bold uppercase tracking-widest text-slate-200 lg:hidden">
      {t.skills.heading}
    </h2>
  </div>

  <div class="flex flex-col gap-6">
    {t.skills.groups.map((group) => (
      <div>
        <h3 class="mb-3 text-xs font-bold uppercase tracking-widest text-slate-500">
          {group.label}
        </h3>
        <ul class="flex flex-wrap gap-2" aria-label={group.label}>
          {group.tags.map((tag) => (
            <li>
              <span class="tag">{tag}</span>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</section>
