---
import type { Translations } from '../i18n/translations';

interface Props {
  t: Translations;
}

const { t } = Astro.props;
---

<footer class="pb-12 pt-6 lg:pb-24">
  <p class="text-xs text-slate-600">
    {t.footer.builtWith} ·{' '}
    <a
      href="https://github.com/kamiljaworski"
      target="_blank"
      rel="noopener noreferrer"
      class="text-slate-500 hover:text-teal-400 transition-colors duration-200"
    >
      kamiljaworski
    </a>
  </p>
</footer>
